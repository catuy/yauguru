---
import Layout from '../layouts/Layout.astro';
import { getBookData, GENRE_LABELS } from '../lib/books';

const { bookData, collectionOptions, genresPresent, years } = await getBookData();

const total = bookData.length;
const dataJson = JSON.stringify(bookData).replace(/</g, '\\u003c');
---

<Layout title={`Catálogo completo (${total} libros) — Yaugurú`}>
	<main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
		<header class="mb-6">
			<a href="/" class="text-sm text-emerald-700 hover:underline">&larr; Inicio</a>
			<h1 class="mt-2 text-2xl font-bold tracking-tight text-stone-900 sm:text-3xl">
				Catálogo completo
			</h1>
			<p class="mt-1 text-stone-600">
				<span id="result-count">{total}</span> de {total} libros
			</p>
		</header>

		<div
			class="mb-4 grid grid-cols-1 gap-3 rounded-lg border border-stone-200 bg-stone-50 p-4 sm:grid-cols-2 lg:grid-cols-6"
		>
			<div class="lg:col-span-2">
				<label for="q" class="block text-xs font-medium text-stone-500">Buscar</label>
				<input
					id="q"
					type="text"
					placeholder="Título, autor…"
					class="mt-1 w-full rounded-md border border-stone-300 px-3 py-1.5 text-sm focus:border-emerald-600 focus:outline-none focus:ring-1 focus:ring-emerald-600"
				/>
			</div>
			<div>
				<label for="f-collection" class="block text-xs font-medium text-stone-500">Colección</label>
				<select
					id="f-collection"
					class="mt-1 w-full rounded-md border border-stone-300 px-2 py-1.5 text-sm"
				>
					<option value="">Todas</option>
					{collectionOptions.map((c) => <option value={c.slug}>{c.name}</option>)}
				</select>
			</div>
			<div>
				<label for="f-genre" class="block text-xs font-medium text-stone-500">Género</label>
				<select id="f-genre" class="mt-1 w-full rounded-md border border-stone-300 px-2 py-1.5 text-sm">
					<option value="">Todos</option>
					{genresPresent.map((g) => <option value={g}>{GENRE_LABELS[g] ?? g}</option>)}
				</select>
			</div>
			<div>
				<label for="f-year" class="block text-xs font-medium text-stone-500">Año</label>
				<select id="f-year" class="mt-1 w-full rounded-md border border-stone-300 px-2 py-1.5 text-sm">
					<option value="">Todos</option>
					{years.map((y) => <option value={y}>{y}</option>)}
				</select>
			</div>
			<div>
				<label for="f-sort" class="block text-xs font-medium text-stone-500">Ordenar por</label>
				<select id="f-sort" class="mt-1 w-full rounded-md border border-stone-300 px-2 py-1.5 text-sm">
					<option value="collection-asc">Colección</option>
					<option value="year-desc">Año (recientes primero)</option>
					<option value="year-asc">Año (antiguos primero)</option>
					<option value="title-asc">Título (A-Z)</option>
					<option value="author-asc">Autor (A-Z)</option>
				</select>
			</div>
			<div class="flex items-end lg:col-span-6">
				<button
					id="reset"
					type="button"
					class="rounded-md border border-stone-300 px-3 py-1.5 text-sm text-stone-600 hover:bg-stone-100"
				>
					Limpiar filtros
				</button>
			</div>
		</div>

		<div class="overflow-x-auto rounded-lg border border-stone-200">
			<table class="min-w-full divide-y divide-stone-200 text-sm">
				<thead class="bg-stone-100 text-left text-xs font-semibold uppercase tracking-wide text-stone-500">
					<tr>
						<th class="px-3 py-2">Título</th>
						<th class="px-3 py-2">Colección</th>
						<th class="px-3 py-2">Año</th>
						<th class="px-3 py-2">Autor(es)</th>
						<th class="px-3 py-2">Género</th>
						<th class="px-3 py-2">Notas</th>
					</tr>
				</thead>
				<tbody id="rows" class="divide-y divide-stone-100 bg-white"></tbody>
			</table>
		</div>
		<p id="empty" class="mt-6 hidden text-center text-stone-500">
			No hay libros que coincidan con los filtros.
		</p>
	</main>

	<script type="application/json" id="books-data" set:html={dataJson} />

	<script>
		const raw = document.getElementById('books-data')?.textContent ?? '[]';
		const books = JSON.parse(raw);

		const GENRE_LABELS: Record<string, string> = {
			'poesía': 'Poesía',
			novela: 'Novela',
			cuentos: 'Cuentos',
			ensayo: 'Ensayo',
			teatro: 'Teatro',
			'audio (cd/dvd)': 'Audio (CD/DVD)',
			historieta: 'Historieta',
			otro: 'Otro',
		};

		const els = {
			q: document.getElementById('q') as HTMLInputElement,
			collection: document.getElementById('f-collection') as HTMLSelectElement,
			genre: document.getElementById('f-genre') as HTMLSelectElement,
			year: document.getElementById('f-year') as HTMLSelectElement,
			sort: document.getElementById('f-sort') as HTMLSelectElement,
			reset: document.getElementById('reset') as HTMLButtonElement,
			rows: document.getElementById('rows') as HTMLTableSectionElement,
			count: document.getElementById('result-count') as HTMLSpanElement,
			empty: document.getElementById('empty') as HTMLParagraphElement,
		};

		function escapeHtml(s: unknown) {
			return String(s).replace(
				/[&<>"']/g,
				(c) =>
					({
						'&': '&amp;',
						'<': '&lt;',
						'>': '&gt;',
						'"': '&quot;',
						"'": '&#39;',
					})[c] as string
			);
		}

		function noteBadges(b: any) {
			const badges: string[] = [];
			if (b.awards?.length)
				badges.push(
					`<span title="${escapeHtml(b.awards.join('; '))}" class="inline-block rounded bg-amber-100 px-1.5 py-0.5 text-xs text-amber-800">Premio</span>`
				);
			if (b.coEdition)
				badges.push(
					`<span title="${escapeHtml(b.coEdition)}" class="inline-block rounded bg-sky-100 px-1.5 py-0.5 text-xs text-sky-800">Co-ed.</span>`
				);
			if (b.translators?.length)
				badges.push(
					`<span title="${escapeHtml(b.translators.join(', '))}" class="inline-block rounded bg-violet-100 px-1.5 py-0.5 text-xs text-violet-800">Trad.</span>`
				);
			if (b.illustrators?.length)
				badges.push(
					`<span title="${escapeHtml(b.illustrators.join(', '))}" class="inline-block rounded bg-rose-100 px-1.5 py-0.5 text-xs text-rose-800">Il.</span>`
				);
			return badges.join(' ');
		}

		function render() {
			const q = els.q.value.trim().toLowerCase();
			const collection = els.collection.value;
			const genre = els.genre.value;
			const year = els.year.value;
			const sort = els.sort.value;

			let filtered = books.filter((b: any) => {
				if (collection && !b.collectionSlugs.includes(collection)) return false;
				if (genre && b.genre !== genre) return false;
				if (year && String(b.year) !== year) return false;
				if (q) {
					const hay = [b.title, ...(b.authors || []), b.series]
						.filter(Boolean)
						.join(' ')
						.toLowerCase();
					if (!hay.includes(q)) return false;
				}
				return true;
			});

			filtered.sort((a: any, b: any) => {
				switch (sort) {
					case 'year-desc':
						return (b.year || 0) - (a.year || 0) || a.title.localeCompare(b.title, 'es');
					case 'year-asc':
						return (a.year || 0) - (b.year || 0) || a.title.localeCompare(b.title, 'es');
					case 'title-asc':
						return a.title.localeCompare(b.title, 'es');
					case 'author-asc':
						return (a.authors[0] || '').localeCompare(b.authors[0] || '', 'es');
					case 'collection-asc':
					default:
						return (
							a.collectionOrder - b.collectionOrder ||
							(a.year || 0) - (b.year || 0) ||
							a.title.localeCompare(b.title, 'es')
						);
				}
			});

			els.count.textContent = String(filtered.length);
			els.empty.classList.toggle('hidden', filtered.length > 0);

			els.rows.innerHTML = filtered
				.map(
					(b: any) => `
				<tr class="hover:bg-stone-50">
					<td class="px-3 py-2 font-medium text-stone-900">${escapeHtml(b.title)}${b.featured ? ' <span class="text-amber-500">★</span>' : ''}</td>
					<td class="px-3 py-2 text-stone-600">${escapeHtml(b.collectionNames.join(', '))}${b.series ? `<br/><span class="text-xs text-stone-400">${escapeHtml(b.series)}</span>` : ''}</td>
					<td class="px-3 py-2 text-stone-600">${b.year ?? '—'}</td>
					<td class="px-3 py-2 text-stone-600">${b.authors.length ? escapeHtml(b.authors.join(', ')) : '<span class="text-stone-300">—</span>'}</td>
					<td class="px-3 py-2 text-stone-600">${b.genre ? escapeHtml(GENRE_LABELS[b.genre] ?? b.genre) : '<span class="text-stone-300">—</span>'}</td>
					<td class="px-3 py-2">${noteBadges(b)}</td>
				</tr>
			`
				)
				.join('');
		}

		['input', 'change'].forEach((evt) => {
			els.q.addEventListener(evt, render);
			els.collection.addEventListener(evt, render);
			els.genre.addEventListener(evt, render);
			els.year.addEventListener(evt, render);
			els.sort.addEventListener(evt, render);
		});
		els.reset.addEventListener('click', () => {
			els.q.value = '';
			els.collection.value = '';
			els.genre.value = '';
			els.year.value = '';
			els.sort.value = 'collection-asc';
			render();
		});

		render();
	</script>
</Layout>
