---
import { getBookData, GENRE_LABELS, buildNotes } from '../lib/books';

interface Props {
	activeSlug?: string;
}

const { activeSlug } = Astro.props;

const { bookData, collectionOptions, genresPresent, years } = await getBookData();
const total = bookData.length;

// Small set of tilt angles cycled across cards, matching the hand-placed look in the design.
const ROTATIONS = [0.8, -0.5, 0.6, -0.8, 0];

// Bundled as one JSON payload (rather than define:vars) so the grid script
// below can stay a plain is:inline script — define:vars always regenerates
// the <script> tag from scratch, silently dropping the data-astro-rerun
// attribute it needs to survive Astro's view-transition script dedup.
const appData = JSON.stringify({ rotations: ROTATIONS, books: bookData }).replace(/</g, '\\u003c');

const activeBook = activeSlug ? bookData.find((b) => b.slug === activeSlug) : undefined;

const infoRows = activeBook
	? ([
			['Título', activeBook.title],
			['Colección', activeBook.collectionNames.join(', ') || '—'],
			['Año', activeBook.year ? String(activeBook.year) : '—'],
			['Autor(es)', activeBook.authors.length ? activeBook.authors.join(', ') : '—'],
			['Género', activeBook.genre ? (GENRE_LABELS[activeBook.genre] ?? activeBook.genre) : '—'],
			...(buildNotes(activeBook) ? [['Notas', buildNotes(activeBook)]] : []),
		] as [string, string][])
	: [];

---

<div id="page-bg" class:list={['w-full', { 'blur-sm': activeBook }]} inert={activeBook ? true : undefined}>
	<section class="w-full bg-primario">
		<div class="mx-auto flex max-w-[1280px] justify-center px-6 py-12 sm:px-16 lg:px-[103px] lg:py-0">
			<img src="/logo-yauguru.png" alt="Yaugurú" class="w-full max-w-[1074px]" />
		</div>
	</section>

	<section class="w-full bg-white px-6 py-14 sm:px-12">
		<div class="mx-auto max-w-[1280px]">
			<div class="max-w-[760px] space-y-6 text-lg leading-[1.6] tracking-[0.18px] text-primario">
				<p>
					El sello editorial YAUGURÚ surge en el 2004 como respuesta a la necesidad de atender la
					creación desde un lugar no estandarizado ni homogéneo. Cada obra, más allá de estilos y
					géneros es única, por tanto el proceso de edición debe tomar en cuenta esa especialidad.
				</p>
				<p>
					La materialidad de la edición pretende hablar precisamente de esos aspectos
					diferenciales. Generalmente las colecciones son armadas con criterios de uniformidad,
					todos son iguales. Sin embargo en la literatura, y en el arte en general, lo que importa
					son las diferencias.
				</p>
				<p>Lo diferente, lo que sale de lo común es lo que nos entusiasma.</p>
				<p>No somos indiferentes a lo diferente.</p>
				<p>La poesía en todos sus géneros.</p>
				<p>La edición en todos sus formatos.</p>
				<p class="flex items-center gap-1">
					<span class="underline decoration-from-font [text-underline-position:from-font]">Leer más</span>
					<span class="underline decoration-from-font [text-underline-position:from-font]">+</span>
				</p>
			</div>
		</div>
	</section>

	<div id="filter-bar-wrap" class="sticky top-0 z-20 w-full border-y border-primario bg-white">
		<div class="relative flex h-[59px] w-full items-center justify-between overflow-x-auto whitespace-nowrap px-6">
			<div class="flex shrink-0 items-center gap-4">
				<button id="btn-filters" type="button" class="cursor-pointer shrink-0 text-lg tracking-[0.18px] text-primario">
					Filtros<span id="filter-count"></span>
				</button>
				<button
					id="btn-clear-filters"
					type="button"
					class="hidden shrink-0 text-lg tracking-[0.18px] text-primario"
				>
					(Borrar filtros)
				</button>
			</div>
			<p class="pointer-events-none absolute left-1/2 hidden -translate-x-1/2 text-lg tracking-[0.18px] text-primario sm:block">
				<span id="result-count">{total}</span> de {total} libros
			</p>
			<div class="flex shrink-0 items-center gap-6 pl-6">
				<button id="btn-view" type="button" class="cursor-pointer shrink-0 text-lg tracking-[0.18px] text-primario">
					Vista: Grilla
				</button>
				<button id="btn-sort" type="button" class="cursor-pointer shrink-0 text-lg tracking-[0.18px] text-primario"></button>
			</div>
		</div>

		<div id="filters-panel" class="hidden border-t border-primario">
			<div class="w-full px-6 py-8">
				<div class="grid grid-cols-2 gap-x-8 gap-y-8 sm:grid-cols-5">
					<div>
						<input
							id="q"
							type="text"
							placeholder="Buscar por título o autor..."
							class="-mx-2 w-full rounded-sm bg-transparent px-2 py-1 text-lg text-primario placeholder:text-primario focus:text-primario/50 focus:placeholder:text-primario/50 focus:outline-none"
						/>
					</div>
					<div>
						<p class="mb-3 text-lg tracking-[0.18px] text-primario">Colección</p>
						<div class="relative">
							<div class="filter-scroll flex max-h-56 flex-col gap-2 overflow-y-auto pr-4">
								<label class="flex cursor-pointer items-center gap-2 text-lg text-primario">
									<input type="radio" name="f-collection" value="" checked class="peer sr-only" />
									<span class="h-3.5 w-3.5 shrink-0 rounded-full border-2 border-primario peer-checked:bg-primario"></span>
									Todas
								</label>
								{collectionOptions.map((c) => (
									<label class="flex cursor-pointer items-center gap-2 text-lg text-primario">
										<input type="radio" name="f-collection" value={c.slug} class="peer sr-only" />
										<span class="h-3.5 w-3.5 shrink-0 rounded-full border-2 border-primario peer-checked:bg-primario"></span>
										{c.name}
									</label>
								))}
							</div>
							<div class="scroll-track pointer-events-none absolute right-0 top-0 hidden h-full w-1 rounded-full bg-primario/15"></div>
							<div class="scroll-thumb pointer-events-none absolute right-0 hidden w-1 rounded-full bg-primario"></div>
						</div>
					</div>
					<div>
						<p class="mb-3 text-lg tracking-[0.18px] text-primario">Género</p>
						<div class="relative">
							<div class="filter-scroll flex max-h-56 flex-col gap-2 overflow-y-auto pr-4">
								<label class="flex cursor-pointer items-center gap-2 text-lg text-primario">
									<input type="radio" name="f-genre" value="" checked class="peer sr-only" />
									<span class="h-3.5 w-3.5 shrink-0 rounded-full border-2 border-primario peer-checked:bg-primario"></span>
									Todos
								</label>
								{genresPresent.map((g) => (
									<label class="flex cursor-pointer items-center gap-2 text-lg text-primario">
										<input type="radio" name="f-genre" value={g} class="peer sr-only" />
										<span class="h-3.5 w-3.5 shrink-0 rounded-full border-2 border-primario peer-checked:bg-primario"></span>
										{GENRE_LABELS[g] ?? g}
									</label>
								))}
							</div>
							<div class="scroll-track pointer-events-none absolute right-0 top-0 hidden h-full w-1 rounded-full bg-primario/15"></div>
							<div class="scroll-thumb pointer-events-none absolute right-0 hidden w-1 rounded-full bg-primario"></div>
						</div>
					</div>
					<div>
						<p class="mb-3 text-lg tracking-[0.18px] text-primario">Año</p>
						<div class="relative">
							<div class="filter-scroll flex max-h-56 flex-col gap-2 overflow-y-auto pr-4">
								<label class="flex cursor-pointer items-center gap-2 text-lg text-primario">
									<input type="radio" name="f-year" value="" checked class="peer sr-only" />
									<span class="h-3.5 w-3.5 shrink-0 rounded-full border-2 border-primario peer-checked:bg-primario"></span>
									Todos
								</label>
								{years.map((y) => (
									<label class="flex cursor-pointer items-center gap-2 text-lg text-primario">
										<input type="radio" name="f-year" value={y} class="peer sr-only" />
										<span class="h-3.5 w-3.5 shrink-0 rounded-full border-2 border-primario peer-checked:bg-primario"></span>
										{y}
									</label>
								))}
							</div>
							<div class="scroll-track pointer-events-none absolute right-0 top-0 hidden h-full w-1 rounded-full bg-primario/15"></div>
							<div class="scroll-thumb pointer-events-none absolute right-0 hidden w-1 rounded-full bg-primario"></div>
						</div>
					</div>
					<div class="col-start-2 flex justify-end sm:col-start-5">
						<button
							id="btn-filters-close"
							type="button"
							aria-label="Cerrar filtros"
							class="flex h-8 w-8 items-center justify-center text-primario"
						>
							<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
								<line x1="2" y1="2" x2="16" y2="16"></line>
								<line x1="16" y1="2" x2="2" y2="16"></line>
							</svg>
						</button>
					</div>
				</div>
			</div>
		</div>
	</div>

	<section class="w-full bg-white p-2">
		<div id="grid" class="mx-auto grid max-w-[1280px] grid-cols-2 gap-2 sm:grid-cols-3 lg:grid-cols-4"></div>
		<p id="empty" class="hidden py-16 text-center text-primario/70">
			No hay libros que coincidan con los filtros.
		</p>
	</section>
</div>

{activeBook && (
	<div id="book-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 sm:p-10">
		<a href="/" aria-label="Cerrar" class="absolute inset-0 bg-white/70"></a>
		<div id="book-modal-content" class="relative flex w-full max-w-3xl flex-col items-center gap-6 sm:flex-row sm:items-start sm:gap-10">
			<a
				href="/"
				aria-label="Cerrar"
				class="absolute -top-12 right-0 flex h-10 w-10 items-center justify-center rounded-full border border-primario bg-white text-primario shadow-[0px_4px_8px_rgba(0,0,0,0.25)] sm:-top-4 sm:-right-14"
			>
				<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
					<line x1="2" y1="2" x2="16" y2="16"></line>
					<line x1="16" y1="2" x2="2" y2="16"></line>
				</svg>
			</a>

			<div class="relative h-[300px] w-[220px] shrink-0 sm:h-[380px] sm:w-[270px]" style="view-transition-name: book-cover">
				<div class="flex h-full w-full flex-col justify-between rounded-sm border border-primario/30 bg-[#faf7f2] p-5 text-primario shadow-[0px_24px_48px_-8px_rgba(0,0,0,0.35)]">
					<p class="text-lg font-semibold leading-snug">{activeBook.title}</p>
					<p class="text-xs uppercase tracking-wide opacity-70">
						{activeBook.authors[0] ?? activeBook.collectionNames[0] ?? ''}
					</p>
				</div>
			</div>

			<div class="w-full max-w-sm border border-primario bg-white px-6 py-2 text-primario shadow-[0px_4px_8px_rgba(0,0,0,0.25)]">
				<dl class="divide-y divide-primario">
					{infoRows.map(([label, value]) => (
						<div class="py-3">
							<dt class="text-[10px] font-bold uppercase text-primario">{label}</dt>
							<dd class="mt-1.5 text-[13px] leading-[1.5] text-primario">{value}</dd>
						</div>
					))}
				</dl>
				{activeBook.purchaseLink && (
					<a
						href={activeBook.purchaseLink}
						target="_blank"
						rel="noopener noreferrer"
						class="my-4 inline-block rounded-sm border border-primario px-4 py-2 text-sm font-medium text-primario hover:bg-primario hover:text-white"
					>
						Comprar
					</a>
				)}
			</div>
		</div>
	</div>
)}

<script type="application/json" id="app-data" set:html={appData} />

<script is:inline data-astro-rerun>
// Without data-astro-rerun, Astro's view-transition swap skips scripts
// whose content is byte-identical to one already run on a previous page
// (true here: this script is the same on every /libro/[slug] page) —
// meaning render() would never fire again and #grid would stay empty
// after navigating back. That in turn means this script's top-level consts
// get (re)declared more than once — is:inline scripts are classic scripts
// sharing one global scope, unlike type="module" ones — so everything is
// wrapped in an IIFE to give each run its own scope.
(function () {
	const { rotations, books } = JSON.parse(document.getElementById('app-data')?.textContent ?? '{}');

	const els = {
		btnView: document.getElementById('btn-view'),
		btnSort: document.getElementById('btn-sort'),
		btnFilters: document.getElementById('btn-filters'),
		btnFiltersClose: document.getElementById('btn-filters-close'),
		btnClear: document.getElementById('btn-clear-filters'),
		filtersPanel: document.getElementById('filters-panel'),
		filterCount: document.getElementById('filter-count'),
		q: document.getElementById('q'),
		grid: document.getElementById('grid'),
		count: document.getElementById('result-count'),
		empty: document.getElementById('empty'),
	};

	const SORT_OPTIONS = [
		{ value: 'title-asc', label: 'Título' },
		{ value: 'author-asc', label: 'Autor' },
		{ value: 'year-desc', label: 'Reciente' },
	];
	let sortIndex = SORT_OPTIONS.findIndex((o) => o.value === 'year-desc');

	function getRadioValue(name) {
		const checked = document.querySelector(`input[name="${name}"]:checked`);
		return checked ? checked.value : '';
	}

	function setRadioValue(name, value) {
		if (typeof value !== 'string') return;
		const radios = document.querySelectorAll(`input[name="${name}"]`);
		let matched = false;
		radios.forEach((r) => {
			if (r.value === value) {
				r.checked = true;
				matched = true;
			}
		});
		if (!matched) {
			const empty = Array.from(radios).find((r) => r.value === '');
			if (empty) empty.checked = true;
		}
	}

	function escapeHtml(s) {
		return String(s ?? '').replace(
			/[&<>"']/g,
			(c) =>
				({
					'&': '&amp;',
					'<': '&lt;',
					'>': '&gt;',
					'"': '&quot;',
					"'": '&#39;',
				})[c]
		);
	}

	function card(b, i) {
		const rotation = rotations[i % rotations.length];
		const cover = `<div class="flex h-[180px] w-[130px] flex-col justify-between rounded-sm border border-primario/30 bg-[#faf7f2] p-3 text-primario shadow-[0px_12px_24px_-4px_rgba(0,0,0,0.15)]">
			<p class="line-clamp-4 text-[11px] font-semibold leading-tight">${escapeHtml(b.title)}</p>
			<p class="line-clamp-1 text-[9px] uppercase tracking-wide opacity-70">${escapeHtml(b.authors[0] ?? b.collectionNames[0] ?? '')}</p>
		</div>`;
		return `
		<div class="flex h-[310px] w-full items-center justify-center">
			<a href="/libro/${encodeURIComponent(b.slug)}" class="book-cover-link relative block h-[180px] w-[130px]" aria-label="Ver ${escapeHtml(b.title)}">
				<div class="book-cover-box absolute inset-0" style="transform: rotate(${rotation}deg)">${cover}</div>
			</a>
		</div>`;
	}

	// Tags only the clicked cover with the shared view-transition name, right
	// before the browser navigates, so the destination page's zoomed cover
	// (which carries the same name) morphs from this exact card instead of
	// every one of the 500+ cards needing a permanent unique name. Clearing
	// any leftover tag first is cheap insurance — two elements sharing the
	// name at once aborts the transition outright instead of just looking
	// wrong.
	els.grid.addEventListener('click', (e) => {
		const link = e.target.closest('.book-cover-link');
		if (!link) return;
		document.querySelectorAll('.book-cover-box[style*="view-transition-name"]').forEach((el) => {
			el.style.viewTransitionName = '';
		});
		const box = link.querySelector('.book-cover-box');
		if (box) box.style.viewTransitionName = 'book-cover';
	});

	// Opening a book (or closing back out of it) is a real navigation to a
	// different page, so the filter/search/sort state would otherwise reset
	// every time — remembered here across that round trip the same way
	// scroll position is (see the other script below), keyed so it survives
	// for the whole session rather than just one hop.
	const FILTERS_KEY = 'yauguru:filters';

	function restoreFilters() {
		const raw = sessionStorage.getItem(FILTERS_KEY);
		if (!raw) return;
		let saved;
		try {
			saved = JSON.parse(raw);
		} catch {
			return;
		}
		if (typeof saved.q === 'string') els.q.value = saved.q;
		setRadioValue('f-collection', saved.collection);
		setRadioValue('f-genre', saved.genre);
		setRadioValue('f-year', saved.year);
		const idx = SORT_OPTIONS.findIndex((o) => o.value === saved.sort);
		if (idx !== -1) sortIndex = idx;
	}

	function activeFilterCount() {
		let n = 0;
		if (els.q.value.trim()) n++;
		if (getRadioValue('f-collection')) n++;
		if (getRadioValue('f-genre')) n++;
		if (getRadioValue('f-year')) n++;
		return n;
	}

	function updateFilterButton() {
		const n = activeFilterCount();
		els.filterCount.textContent = n > 0 ? ` (${n})` : '';
		els.btnClear.classList.toggle('hidden', n === 0);
	}

	function setFiltersOpen(open) {
		els.filtersPanel.classList.toggle('hidden', !open);
		if (open) {
			// The panel is display:none right up until this toggle, so any
			// earlier measurement of the scroll columns (at page load, when
			// they were still hidden) read zero height. Re-measure now that
			// it's actually laid out — one frame so the class change above
			// has taken effect first.
			requestAnimationFrame(() => scrollThumbUpdaters.forEach((update) => update()));
		}
	}

	function updateSortButton() {
		els.btnSort.textContent = `Orden: ${SORT_OPTIONS[sortIndex].label}`;
	}

	function render() {
		const collection = getRadioValue('f-collection');
		const genre = getRadioValue('f-genre');
		const year = getRadioValue('f-year');
		const sort = SORT_OPTIONS[sortIndex].value;

		sessionStorage.setItem(
			FILTERS_KEY,
			JSON.stringify({ q: els.q.value, collection, genre, year, sort })
		);
		updateFilterButton();
		updateSortButton();

		const q = els.q.value.trim().toLowerCase();

		let filtered = books.filter((b) => {
			if (collection && !b.collectionSlugs.includes(collection)) return false;
			if (genre && b.genre !== genre) return false;
			if (year && String(b.year) !== year) return false;
			if (q) {
				const hay = [b.title, ...(b.authors || []), b.series].filter(Boolean).join(' ').toLowerCase();
				if (!hay.includes(q)) return false;
			}
			return true;
		});

		filtered.sort((a, b) => {
			switch (sort) {
				case 'title-asc':
					return a.title.localeCompare(b.title, 'es');
				case 'author-asc':
					return (a.authors[0] || '').localeCompare(b.authors[0] || '', 'es');
				case 'year-desc':
				default:
					return (b.year || 0) - (a.year || 0) || a.title.localeCompare(b.title, 'es');
			}
		});

		els.count.textContent = String(filtered.length);
		els.empty.classList.toggle('hidden', filtered.length > 0);
		els.grid.innerHTML = filtered.map(card).join('');
	}

	els.q.addEventListener('input', render);
	els.filtersPanel.addEventListener('change', (e) => {
		if (e.target instanceof HTMLInputElement && e.target.type === 'radio') render();
	});

	els.btnClear.addEventListener('click', () => {
		els.q.value = '';
		setRadioValue('f-collection', '');
		setRadioValue('f-genre', '');
		setRadioValue('f-year', '');
		render();
	});

	els.btnFilters.addEventListener('click', () => {
		setFiltersOpen(els.filtersPanel.classList.contains('hidden'));
	});
	els.btnFiltersClose.addEventListener('click', () => setFiltersOpen(false));

	els.btnSort.addEventListener('click', () => {
		sortIndex = (sortIndex + 1) % SORT_OPTIONS.length;
		render();
	});

	els.btnView.addEventListener('click', () => {
		window.location.href = '/catalogo';
	});

	// Hand-drawn scroll thumb for each filter column (native scrollbars
	// auto-hide on macOS/Safari regardless of ::-webkit-scrollbar styling —
	// see global.css). Track/thumb are hidden by default and only shown
	// once we know the list actually overflows. The panel is display:none
	// at this point in the script (page just loaded), so every list reads
	// zero height here — these first update() calls just wire the scroll
	// listener; setFiltersOpen re-measures for real once it's visible.
	const scrollThumbUpdaters = [];

	function setupScrollThumb(list) {
		const wrap = list.parentElement;
		const track = wrap.querySelector('.scroll-track');
		const thumb = wrap.querySelector('.scroll-thumb');
		if (!track || !thumb) return;

		function update() {
			const trackHeight = list.clientHeight;
			const contentHeight = list.scrollHeight;
			const overflows = contentHeight > trackHeight + 1;
			track.classList.toggle('hidden', !overflows);
			thumb.classList.toggle('hidden', !overflows);
			if (!overflows) return;

			const thumbHeight = Math.max((trackHeight / contentHeight) * trackHeight, 20);
			const maxThumbTop = trackHeight - thumbHeight;
			const scrollableDistance = contentHeight - trackHeight;
			const scrollRatio = scrollableDistance > 0 ? list.scrollTop / scrollableDistance : 0;
			thumb.style.height = `${thumbHeight}px`;
			thumb.style.top = `${scrollRatio * maxThumbTop}px`;
		}

		list.addEventListener('scroll', update);
		scrollThumbUpdaters.push(update);
		update();
	}

	document.querySelectorAll('.filter-scroll').forEach(setupScrollThumb);

	restoreFilters();
	render();
})();
</script>

<script is:inline>
	// Guarded because Astro's view-transition navigations can re-run this
	// script without a full document reload, and these listeners only need
	// to be attached once for the whole session (they live on `document`,
	// which persists across soft navigations).
	if (!window.__yauguruTransitionsBound) {
		window.__yauguruTransitionsBound = true;

		// Escape closes the detail modal by re-using the real close link, so
		// it goes through the same navigation (and view transition) as
		// clicking it.
		document.addEventListener('keydown', (e) => {
			if (e.key !== 'Escape') return;
			const closeLink = document.querySelector('#book-modal a[aria-label="Cerrar"]');
			if (closeLink instanceof HTMLElement) closeLink.click();
		});

		// The grid is built client-side, so the specific card a closing book
		// should shrink back into doesn't exist yet at the moment the browser
		// snapshots the destination page — Astro only re-runs page scripts
		// (which is what builds it) after that snapshot is already taken, so
		// landing precisely on the grid card isn't possible without
		// server-rendering the whole grid. Instead, on close, the whole modal
		// (cover + info panel together) gets a single standalone fade/blur
		// exit (see global.css): drop the cover's own morph name first so it
		// doesn't separately hunt for a same-page match, then name the
		// modal's content wrapper as one unit right before navigating away.
		// Delegated on document (not #book-modal, which doesn't exist yet the
		// first time this guarded, run-once block executes).
		document.addEventListener('click', (e) => {
			const link = e.target.closest('#book-modal a[aria-label="Cerrar"]');
			if (!link) return;
			const cover = document.querySelector('[style*="view-transition-name: book-cover"]');
			if (cover instanceof HTMLElement) cover.style.viewTransitionName = '';
			const content = document.getElementById('book-modal-content');
			if (content) content.style.viewTransitionName = 'book-modal-exit';
		});

		// Opening/closing the book detail is a real navigation (for the
		// shareable URL), which would otherwise reset scroll to the top and
		// make the blurred grid behind the modal jump. Remember where we
		// were right before leaving a page, and restore it once the next
		// one is ready, so the background stays put in both directions.
		const SCROLL_KEY = 'yauguru:scrollY';
		document.addEventListener('astro:before-preparation', () => {
			sessionStorage.setItem(SCROLL_KEY, String(window.scrollY));
		});
		document.addEventListener('astro:page-load', () => {
			const saved = sessionStorage.getItem(SCROLL_KEY);
			// The browser's own view-transition machinery (scrolling the
			// outgoing named element into view to snapshot it) can still
			// adjust scroll for a frame or two after astro:page-load fires,
			// silently winning over a scrollTo() called here directly.
			// Waiting two animation frames lets that settle first.
			requestAnimationFrame(() => {
				requestAnimationFrame(() => {
					if (saved !== null) {
						window.scrollTo(0, parseInt(saved, 10));
						return;
					}
					// No saved position means this book page was opened
					// directly (shared link, fresh tab, reload) rather than
					// clicked from the grid — there's nothing to "return"
					// to. Scroll to where the book sits in the (blurred)
					// grid instead of leaving the hero visible behind it.
					const modal = document.getElementById('book-modal');
					if (!modal) return;
					const match = location.pathname.match(/^\/libro\/([^/]+)/);
					const slug = match ? decodeURIComponent(match[1]) : null;
					const card = slug
						? document.querySelector(`.book-cover-link[href="/libro/${CSS.escape(slug)}"]`)
						: null;
					if (card) {
						const rect = card.getBoundingClientRect();
						const target = rect.top + window.scrollY - window.innerHeight / 2 + rect.height / 2;
						window.scrollTo(0, Math.max(target, 0));
					} else {
						document.getElementById('grid')?.scrollIntoView({ block: 'start' });
					}
				});
			});
		});
	}
</script>
