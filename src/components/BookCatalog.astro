---
import { getBookData, GENRE_LABELS } from '../lib/books';

interface Props {
	activeSlug?: string;
}

const { activeSlug } = Astro.props;

const { bookData, collectionOptions, genresPresent, years } = await getBookData();
const total = bookData.length;

// Small set of tilt angles cycled across cards, matching the hand-placed look in the design.
const ROTATIONS = [0.8, -0.5, 0.6, -0.8, 0];

// Bundled as one JSON payload (rather than define:vars) so the grid script
// below can stay a plain is:inline script — define:vars always regenerates
// the <script> tag from scratch, silently dropping the data-astro-rerun
// attribute it needs to survive Astro's view-transition script dedup.
const appData = JSON.stringify({ rotations: ROTATIONS, books: bookData }).replace(/</g, '\\u003c');

const activeBook = activeSlug ? bookData.find((b) => b.slug === activeSlug) : undefined;

const infoRows = activeBook
	? ([
			['Título', activeBook.title],
			['Colección', activeBook.collectionNames.join(', ') || '—'],
			['Año', activeBook.year ? String(activeBook.year) : '—'],
			['Autor(es)', activeBook.authors.length ? activeBook.authors.join(', ') : '—'],
			['Género', activeBook.genre ? (GENRE_LABELS[activeBook.genre] ?? activeBook.genre) : '—'],
			...(activeBook.notes ? [['Notas', activeBook.notes]] : []),
		] as [string, string][])
	: [];

---

<div id="page-bg" class:list={['w-full', { 'blur-sm': activeBook }]} inert={activeBook ? true : undefined}>
	<section class="flex h-screen w-full items-center bg-primario">
		<div class="mx-auto flex w-full max-w-[1280px] justify-center px-6 sm:px-16 lg:px-[103px]">
			<img src="/logo-yauguru.png" alt="Yaugurú" class="w-full max-w-[1074px]" />
		</div>
	</section>

	<section id="about-section" class="relative w-full bg-white px-6 py-14">
		<canvas
			id="about-canvas"
			class="pointer-events-none absolute inset-0"
			transition:persist
			transition:name="about-canvas"
		></canvas>
		<div class="grid grid-cols-1 gap-x-16 gap-y-10 text-lg leading-[1.6] tracking-[0.18px] text-primario sm:grid-cols-2">
			<div class="[&>p]:mb-6">
				<p>
					El sello editorial YAUGURÚ surge en el 2004 como respuesta a la necesidad de atender la
					creación desde un lugar no estandarizado ni homogéneo. Cada obra, más allá de estilos y
					géneros es única, por tanto el proceso de edición debe tomar en cuenta esa especialidad.
				</p>
				<p>
					La materialidad de la edición pretende hablar precisamente de esos aspectos
					diferenciales. Generalmente las colecciones son armadas con criterios de uniformidad,
					todos son iguales. Sin embargo en la literatura, y en el arte en general, lo que importa
					son las diferencias.
				</p>
				<p>Lo diferente, lo que sale de lo común es lo que nos entusiasma.</p>
				<p>No somos indiferentes a lo diferente.</p>
				<p>La poesía en todos sus géneros.</p>
				<p>La edición en todos sus formatos.</p>
				<p>
					De alguna manera se plantea una continuidad conceptual con lo que fuera el colectivo de
					trabajo Ediciones de UNO (1982-93), sello editorial que contó con más de 100 títulos
					fundamentalmente de poesía, aunque también de narrativa, teatro, historietas y ensayo. Su
					sistema de suscriptores llegó a contar con 600 socios-suscriptores. También se destacó su
					actividad de recitales y performances en teatros, locales sindicales, peñas estudiantes,
					cooperativas de vivienda, etc..
				</p>
				<p>
					Conmemorando su quinto aniversario, el sello editorial yaugurú creó su propio sistema de
					suscriptores, mediante el cual cada socio-suscriptor con el pago de una mínima cuota
					mensual recibe en su casa una publicación –preferentemente libros, aunque también CDs,
					colección de afiches, etc.–. En el momento EL CLÚ DE YAUGURÚ cuenta con aproximadamente
					150 socios-suscriptores.
				</p>
				<p>
					La editorial yaugurú obtiene el Premio al Mérito Gráfico y Esfuerzo Editorial, otorgado
					por la Cámara Uruguaya del Libro en 2010, y el Morosoli institucional otorgado por la
					Fundación Lolita Rubial, en 2018.
				</p>
				<p>El sello lleva editados más de 600 títulos.</p>
				<p>
					<a href="" class="underline decoration-from-font [text-underline-position:from-font]">email</a>
				</p>
				<p>
					<a href="" class="underline decoration-from-font [text-underline-position:from-font]">instagram</a>
				</p>
				<p>
					<a href="" class="underline decoration-from-font [text-underline-position:from-font]">youtube</a>
				</p>
			</div>
			<div class="sticky top-6 self-start [&>p]:mb-6"></div>
		</div>
	</section>

	<div id="filter-bar-sentinel" class="h-px" transition:persist transition:name="filter-bar-sentinel"></div>

	<div id="filter-bar-wrap" class="sticky top-0 z-20 w-full bg-white">
		<div class="mx-6 border-y border-primario">
			<div class="relative flex h-[59px] w-full items-center justify-between overflow-x-auto whitespace-nowrap">
				<div class="flex shrink-0 items-center gap-4">
					<button id="btn-filters" type="button" class="cursor-pointer shrink-0 text-lg tracking-[0.18px] text-primario">
						Filtros<span id="filter-count"></span>
					</button>
					<button
						id="btn-clear-filters"
						type="button"
						class="hidden shrink-0 text-lg tracking-[0.18px] text-primario"
					>
						(Borrar filtros)
					</button>
				</div>
				<p class="pointer-events-none absolute left-1/2 hidden -translate-x-1/2 text-lg tracking-[0.18px] text-primario sm:block">
					<span id="result-count">{total}</span> de {total} libros
				</p>
				<div class="flex shrink-0 items-center gap-6 pl-6">
					<button id="btn-view" type="button" class="cursor-pointer shrink-0 text-lg tracking-[0.18px] text-primario">
						Vista: Grilla
					</button>
					<button id="btn-sort" type="button" class="cursor-pointer shrink-0 text-lg tracking-[0.18px] text-primario"></button>
				</div>
			</div>

			<div id="filters-panel" class="hidden border-t border-primario">
				<div class="w-full py-8">
				<div class="grid grid-cols-2 gap-x-8 gap-y-8 sm:grid-cols-5">
					<div>
						<input
							id="q"
							type="text"
							placeholder="Buscar por título o autor..."
							class="-mx-2 w-full rounded-sm bg-transparent px-2 py-1 text-lg text-primario placeholder:text-primario focus:text-primario/50 focus:placeholder:text-primario/50 focus:outline-none"
						/>
					</div>
					<div>
						<p class="mb-3 text-lg tracking-[0.18px] text-primario">Colección</p>
						<div class="relative">
							<div class="filter-scroll flex max-h-56 flex-col gap-2 overflow-y-auto pr-4">
								<label class="flex cursor-pointer items-center gap-2 text-lg text-primario">
									<input type="radio" name="f-collection" value="" checked class="peer sr-only" />
									<span class="h-3.5 w-3.5 shrink-0 rounded-full border-2 border-primario peer-checked:bg-primario"></span>
									Todas
								</label>
								{collectionOptions.map((c) => (
									<label class="flex cursor-pointer items-center gap-2 text-lg text-primario">
										<input type="radio" name="f-collection" value={c.slug} class="peer sr-only" />
										<span class="h-3.5 w-3.5 shrink-0 rounded-full border-2 border-primario peer-checked:bg-primario"></span>
										{c.name}
									</label>
								))}
							</div>
							<div class="scroll-track pointer-events-none absolute right-0 top-0 hidden h-full w-1 rounded-full bg-primario/15"></div>
							<div class="scroll-thumb pointer-events-none absolute right-0 hidden w-1 rounded-full bg-primario"></div>
						</div>
					</div>
					<div>
						<p class="mb-3 text-lg tracking-[0.18px] text-primario">Género</p>
						<div class="relative">
							<div class="filter-scroll flex max-h-56 flex-col gap-2 overflow-y-auto pr-4">
								<label class="flex cursor-pointer items-center gap-2 text-lg text-primario">
									<input type="radio" name="f-genre" value="" checked class="peer sr-only" />
									<span class="h-3.5 w-3.5 shrink-0 rounded-full border-2 border-primario peer-checked:bg-primario"></span>
									Todos
								</label>
								{genresPresent.map((g) => (
									<label class="flex cursor-pointer items-center gap-2 text-lg text-primario">
										<input type="radio" name="f-genre" value={g} class="peer sr-only" />
										<span class="h-3.5 w-3.5 shrink-0 rounded-full border-2 border-primario peer-checked:bg-primario"></span>
										{GENRE_LABELS[g] ?? g}
									</label>
								))}
							</div>
							<div class="scroll-track pointer-events-none absolute right-0 top-0 hidden h-full w-1 rounded-full bg-primario/15"></div>
							<div class="scroll-thumb pointer-events-none absolute right-0 hidden w-1 rounded-full bg-primario"></div>
						</div>
					</div>
					<div>
						<p class="mb-3 text-lg tracking-[0.18px] text-primario">Año</p>
						<div class="relative">
							<div class="filter-scroll flex max-h-56 flex-col gap-2 overflow-y-auto pr-4">
								<label class="flex cursor-pointer items-center gap-2 text-lg text-primario">
									<input type="radio" name="f-year" value="" checked class="peer sr-only" />
									<span class="h-3.5 w-3.5 shrink-0 rounded-full border-2 border-primario peer-checked:bg-primario"></span>
									Todos
								</label>
								{years.map((y) => (
									<label class="flex cursor-pointer items-center gap-2 text-lg text-primario">
										<input type="radio" name="f-year" value={y} class="peer sr-only" />
										<span class="h-3.5 w-3.5 shrink-0 rounded-full border-2 border-primario peer-checked:bg-primario"></span>
										{y}
									</label>
								))}
							</div>
							<div class="scroll-track pointer-events-none absolute right-0 top-0 hidden h-full w-1 rounded-full bg-primario/15"></div>
							<div class="scroll-thumb pointer-events-none absolute right-0 hidden w-1 rounded-full bg-primario"></div>
						</div>
					</div>
					<div class="col-start-2 flex justify-end sm:col-start-5">
						<button
							id="btn-filters-close"
							type="button"
							aria-label="Cerrar filtros"
							class="flex h-8 w-8 items-center justify-center text-primario"
						>
							<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
								<line x1="2" y1="2" x2="16" y2="16"></line>
								<line x1="16" y1="2" x2="2" y2="16"></line>
							</svg>
						</button>
					</div>
				</div>
			</div>
		</div>
	</div>
	</div>

	<section id="grid-section" class="w-full bg-white px-6 py-6">
		<div id="grid"></div>
		<p id="empty" class="hidden py-16 text-center text-primario/70">
			No hay libros que coincidan con los filtros.
		</p>
	</section>
</div>

{activeBook && (
	<div id="book-modal" class="fixed inset-0 z-50">
		<a href="/" aria-label="Cerrar" class="absolute inset-0"></a>
		<div id="book-modal-content" class="relative flex h-full w-full flex-col overflow-y-auto bg-white sm:flex-row sm:overflow-visible">
			<div class="m-6 flex h-[45vh] w-full shrink-0 items-center justify-center bg-[#F9F9F9] sm:h-auto sm:flex-1 sm:self-stretch">
				<div
					class="relative flex h-[300px] w-[220px] items-center justify-center sm:h-[520px] sm:w-[380px]"
					style="view-transition-name: book-cover"
				>
					{activeBook.coverImage ? (
						<img
							src={activeBook.coverImage}
							alt={activeBook.title}
							class="book-shadow-lg max-h-full max-w-full h-auto w-auto"
						/>
					) : (
						<div class="book-shadow-lg flex h-full w-full flex-col justify-between bg-[#faf7f2] p-5 text-primario">
							<p class="text-lg font-semibold leading-snug">{activeBook.title}</p>
							<p class="text-xs uppercase tracking-wide opacity-70">
								{activeBook.authors[0] ?? activeBook.collectionNames[0] ?? ''}
							</p>
						</div>
					)}
				</div>
			</div>

			<div class="w-full shrink-0 bg-white px-6 pb-6 pt-0 text-primario sm:h-full sm:w-[380px] sm:overflow-y-auto sm:pl-0 sm:pt-6">
				<dl class="divide-y divide-primario">
					{infoRows.map(([label, value]) => (
						<div class="py-3">
							<dt class="text-[10px] font-bold uppercase text-primario">{label}</dt>
							<dd class="mt-1.5 text-lg leading-[1.6] tracking-[0.18px] text-primario">{value}</dd>
						</div>
					))}
				</dl>
			</div>
		</div>
	</div>
)}

<div
	id="cursor-dot"
	class="pointer-events-none fixed left-0 top-0 z-[9999] flex h-[10px] w-[10px] items-center justify-center rounded-full bg-primario transition-[width,height,background-color] duration-150 ease-out will-change-transform"
	transition:persist
>
	<span class="text-lg leading-none text-white">+</span>
	<svg
		class="cursor-pencil-icon h-[22px] w-[22px] -translate-y-0.5 translate-x-0.5 text-primario"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
	>
		<path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"></path>
		<path d="M15 5l4 4"></path>
	</svg>
</div>

<div
	id="site-footer"
	class="pointer-events-none fixed inset-x-0 bottom-0 z-20 w-full bg-white opacity-0 transition-opacity duration-200"
	transition:persist
	transition:name="site-footer-bar"
>
	<div class="mx-6 border-y border-primario">
		<div class="flex h-[59px] w-full items-center justify-between">
			<button id="btn-back-to-top" type="button" class="cursor-pointer shrink-0 text-lg tracking-[0.18px] text-primario">
				Volver arriba
			</button>
			<a
				href="https://catuy.github.io/"
				target="_blank"
				rel="noopener noreferrer"
				class="shrink-0 text-lg tracking-[0.18px] text-primario underline decoration-from-font [text-underline-position:from-font]"
			>
				&lt;/&gt;
			</a>
		</div>
	</div>
</div>

<script type="application/json" id="app-data" set:html={appData} />

<script is:inline data-astro-rerun>
// Without data-astro-rerun, Astro's view-transition swap skips scripts
// whose content is byte-identical to one already run on a previous page
// (true here: this script is the same on every /libro/[slug] page) —
// meaning render() would never fire again and #grid would stay empty
// after navigating back. That in turn means this script's top-level consts
// get (re)declared more than once — is:inline scripts are classic scripts
// sharing one global scope, unlike type="module" ones — so everything is
// wrapped in an IIFE to give each run its own scope.
(function () {
	const { rotations, books } = JSON.parse(document.getElementById('app-data')?.textContent ?? '{}');

	const els = {
		btnView: document.getElementById('btn-view'),
		btnSort: document.getElementById('btn-sort'),
		btnFilters: document.getElementById('btn-filters'),
		btnFiltersClose: document.getElementById('btn-filters-close'),
		btnClear: document.getElementById('btn-clear-filters'),
		filtersPanel: document.getElementById('filters-panel'),
		filterCount: document.getElementById('filter-count'),
		q: document.getElementById('q'),
		gridSection: document.getElementById('grid-section'),
		grid: document.getElementById('grid'),
		count: document.getElementById('result-count'),
		empty: document.getElementById('empty'),
	};

	const SORT_OPTIONS = [
		{ value: 'title-asc', label: 'Título' },
		{ value: 'author-asc', label: 'Autor' },
		{ value: 'year-desc', label: 'Reciente' },
	];
	let sortIndex = SORT_OPTIONS.findIndex((o) => o.value === 'year-desc');

	const VIEW_MODES = ['grid', 'list'];
	let viewMode = 'grid';
	const GRID_CLASSES = ['grid', 'grid-cols-2', 'gap-2', 'sm:grid-cols-3', 'lg:grid-cols-4'];
	// No divide-y here: the divider between rows is drawn by .list-row's own
	// ::after (see global.css) so it can be inset 24px like the filter bar's
	// border, instead of divide-y's border-top spanning the full row width.
	const LIST_CLASSES = ['flex', 'flex-col'];

	function getRadioValue(name) {
		const checked = document.querySelector(`input[name="${name}"]:checked`);
		return checked ? checked.value : '';
	}

	function setRadioValue(name, value) {
		if (typeof value !== 'string') return;
		const radios = document.querySelectorAll(`input[name="${name}"]`);
		let matched = false;
		radios.forEach((r) => {
			if (r.value === value) {
				r.checked = true;
				matched = true;
			}
		});
		if (!matched) {
			const empty = Array.from(radios).find((r) => r.value === '');
			if (empty) empty.checked = true;
		}
	}

	function escapeHtml(s) {
		return String(s ?? '').replace(
			/[&<>"']/g,
			(c) =>
				({
					'&': '&amp;',
					'<': '&lt;',
					'>': '&gt;',
					'"': '&quot;',
					"'": '&#39;',
				})[c]
		);
	}

	function card(b, i) {
		const rotation = rotations[i % rotations.length];
		const cover = b.coverImage
			? `<img src="${escapeHtml(b.coverImage)}" alt="${escapeHtml(b.title)}" loading="lazy" decoding="async" class="book-shadow max-h-full max-w-full h-auto w-auto">`
			: `<div class="book-shadow flex h-[260px] w-[190px] flex-col justify-between bg-[#faf7f2] p-3 text-primario">
			<p class="line-clamp-4 text-sm font-semibold leading-tight">${escapeHtml(b.title)}</p>
			<p class="line-clamp-1 text-xs uppercase tracking-wide opacity-70">${escapeHtml(b.authors[0] ?? b.collectionNames[0] ?? '')}</p>
		</div>`;
		return `
		<a href="/libro/${encodeURIComponent(b.slug)}" class="book-cell book-cover-link relative flex h-[450px] w-full items-center justify-center overflow-hidden bg-[#F9F9F9]" aria-label="Ver ${escapeHtml(b.title)}">
			<div class="book-cover-box relative flex h-[260px] w-[190px] items-center justify-center" style="--rotate: ${rotation}deg">${cover}</div>
		</a>`;
	}

	// No hay una tapa que animar en este modo, así que el link no lleva
	// .book-cover-box: el click handler de abajo no encuentra nada para
	// taggear y la navegación usa la transición de página por defecto en
	// lugar del zoom compartido de la vista de grilla.
	function row(b) {
		return `
		<a href="/libro/${encodeURIComponent(b.slug)}" class="list-row book-cover-link relative flex h-[59px] w-full items-center gap-6 overflow-hidden px-6 text-lg tracking-[0.18px] text-primario" aria-label="Ver ${escapeHtml(b.title)}">
			<span class="relative z-[1] min-w-0 flex-1 truncate">${escapeHtml(b.title)}</span>
			<span class="relative z-[1] w-40 shrink-0 truncate sm:w-56">${escapeHtml(b.authors.join(', ') || '—')}</span>
			<span class="relative z-[1] w-12 shrink-0 text-right">${b.year ?? '—'}</span>
		</a>`;
	}

	// Tags only the clicked cover with the shared view-transition name, right
	// before the browser navigates, so the destination page's zoomed cover
	// (which carries the same name) morphs from this exact card instead of
	// every one of the 500+ cards needing a permanent unique name. Clearing
	// any leftover tag first is cheap insurance — two elements sharing the
	// name at once aborts the transition outright instead of just looking
	// wrong.
	els.grid.addEventListener('click', (e) => {
		const link = e.target.closest('.book-cover-link');
		if (!link) return;
		document.querySelectorAll('.book-cover-box[style*="view-transition-name"]').forEach((el) => {
			el.style.viewTransitionName = '';
		});
		const box = link.querySelector('.book-cover-box');
		if (box) box.style.viewTransitionName = 'book-cover';
	});

	// Opening a book (or closing back out of it) is a real navigation to a
	// different page, so the filter/search/sort state would otherwise reset
	// every time — remembered here across that round trip the same way
	// scroll position is (see the other script below), keyed so it survives
	// for the whole session rather than just one hop.
	const FILTERS_KEY = 'yauguru:filters';

	function restoreFilters() {
		const raw = sessionStorage.getItem(FILTERS_KEY);
		if (!raw) return;
		let saved;
		try {
			saved = JSON.parse(raw);
		} catch {
			return;
		}
		if (typeof saved.q === 'string') els.q.value = saved.q;
		setRadioValue('f-collection', saved.collection);
		setRadioValue('f-genre', saved.genre);
		setRadioValue('f-year', saved.year);
		const idx = SORT_OPTIONS.findIndex((o) => o.value === saved.sort);
		if (idx !== -1) sortIndex = idx;
		if (VIEW_MODES.includes(saved.view)) viewMode = saved.view;
	}

	function activeFilterCount() {
		let n = 0;
		if (els.q.value.trim()) n++;
		if (getRadioValue('f-collection')) n++;
		if (getRadioValue('f-genre')) n++;
		if (getRadioValue('f-year')) n++;
		return n;
	}

	function updateFilterButton() {
		const n = activeFilterCount();
		els.filterCount.textContent = n > 0 ? ` (${n})` : '';
		els.btnClear.classList.toggle('hidden', n === 0);
	}

	function setFiltersOpen(open) {
		els.filtersPanel.classList.toggle('hidden', !open);
		if (open) {
			// The panel is display:none right up until this toggle, so any
			// earlier measurement of the scroll columns (at page load, when
			// they were still hidden) read zero height. Re-measure now that
			// it's actually laid out — one frame so the class change above
			// has taken effect first.
			requestAnimationFrame(() => scrollThumbUpdaters.forEach((update) => update()));
		}
	}

	function updateSortButton() {
		els.btnSort.textContent = `Orden: ${SORT_OPTIONS[sortIndex].label}`;
	}

	function updateViewButton() {
		els.btnView.textContent = `Vista: ${viewMode === 'grid' ? 'Grilla' : 'Lista'}`;
	}

	// La sección de la grilla trae su propio padding (p-6, el mismo margen
	// que se usa en la barra de filtros y el texto de about, en los cuatro
	// lados) para separar las tarjetas del borde de la ventana; la lista,
	// en cambio, ya tiene ese margen en cada fila (px-6) y debe quedar a
	// ras como la barra de filtros arriba, así que ese padding se saca por
	// completo en ese modo.
	function updateGridClasses() {
		els.grid.classList.remove(...GRID_CLASSES, ...LIST_CLASSES);
		els.grid.classList.add(...(viewMode === 'grid' ? GRID_CLASSES : LIST_CLASSES));
		els.gridSection.classList.toggle('px-6', viewMode === 'grid');
		els.gridSection.classList.toggle('py-6', viewMode === 'grid');
	}

	function render() {
		const collection = getRadioValue('f-collection');
		const genre = getRadioValue('f-genre');
		const year = getRadioValue('f-year');
		const sort = SORT_OPTIONS[sortIndex].value;

		sessionStorage.setItem(
			FILTERS_KEY,
			JSON.stringify({ q: els.q.value, collection, genre, year, sort, view: viewMode })
		);
		updateFilterButton();
		updateSortButton();
		updateViewButton();
		updateGridClasses();

		const q = els.q.value.trim().toLowerCase();

		let filtered = books.filter((b) => {
			if (collection && !b.collectionSlugs.includes(collection)) return false;
			if (genre && b.genre !== genre) return false;
			if (year && String(b.year) !== year) return false;
			if (q) {
				const hay = [b.title, ...(b.authors || []), b.series].filter(Boolean).join(' ').toLowerCase();
				if (!hay.includes(q)) return false;
			}
			return true;
		});

		filtered.sort((a, b) => {
			switch (sort) {
				case 'title-asc':
					return a.title.localeCompare(b.title, 'es');
				case 'author-asc':
					return (a.authors[0] || '').localeCompare(b.authors[0] || '', 'es');
				case 'year-desc':
				default:
					return (b.year || 0) - (a.year || 0) || a.title.localeCompare(b.title, 'es');
			}
		});

		els.count.textContent = String(filtered.length);
		els.empty.classList.toggle('hidden', filtered.length > 0);
		els.grid.innerHTML = filtered.map((b, i) => (viewMode === 'grid' ? card(b, i) : row(b))).join('');
	}

	els.q.addEventListener('input', render);
	els.filtersPanel.addEventListener('change', (e) => {
		if (e.target instanceof HTMLInputElement && e.target.type === 'radio') render();
	});

	els.btnClear.addEventListener('click', () => {
		els.q.value = '';
		setRadioValue('f-collection', '');
		setRadioValue('f-genre', '');
		setRadioValue('f-year', '');
		render();
	});

	els.btnFilters.addEventListener('click', () => {
		setFiltersOpen(els.filtersPanel.classList.contains('hidden'));
	});
	els.btnFiltersClose.addEventListener('click', () => setFiltersOpen(false));

	els.btnSort.addEventListener('click', () => {
		sortIndex = (sortIndex + 1) % SORT_OPTIONS.length;
		render();
	});

	els.btnView.addEventListener('click', () => {
		viewMode = viewMode === 'grid' ? 'list' : 'grid';
		render();
	});

	// Hand-drawn scroll thumb for each filter column (native scrollbars
	// auto-hide on macOS/Safari regardless of ::-webkit-scrollbar styling —
	// see global.css). Track/thumb are hidden by default and only shown
	// once we know the list actually overflows. The panel is display:none
	// at this point in the script (page just loaded), so every list reads
	// zero height here — these first update() calls just wire the scroll
	// listener; setFiltersOpen re-measures for real once it's visible.
	const scrollThumbUpdaters = [];

	function setupScrollThumb(list) {
		const wrap = list.parentElement;
		const track = wrap.querySelector('.scroll-track');
		const thumb = wrap.querySelector('.scroll-thumb');
		if (!track || !thumb) return;

		function update() {
			const trackHeight = list.clientHeight;
			const contentHeight = list.scrollHeight;
			const overflows = contentHeight > trackHeight + 1;
			track.classList.toggle('hidden', !overflows);
			thumb.classList.toggle('hidden', !overflows);
			if (!overflows) return;

			const thumbHeight = Math.max((trackHeight / contentHeight) * trackHeight, 20);
			const maxThumbTop = trackHeight - thumbHeight;
			const scrollableDistance = contentHeight - trackHeight;
			const scrollRatio = scrollableDistance > 0 ? list.scrollTop / scrollableDistance : 0;
			thumb.style.height = `${thumbHeight}px`;
			thumb.style.top = `${scrollRatio * maxThumbTop}px`;
		}

		list.addEventListener('scroll', update);
		scrollThumbUpdaters.push(update);
		update();
	}

	document.querySelectorAll('.filter-scroll').forEach(setupScrollThumb);

	restoreFilters();
	render();
})();
</script>

<script is:inline>
	// Guarded because Astro's view-transition navigations can re-run this
	// script without a full document reload, and these listeners only need
	// to be attached once for the whole session (they live on `document`,
	// which persists across soft navigations).
	if (!window.__yauguruTransitionsBound) {
		window.__yauguruTransitionsBound = true;

		// Trailing cursor dot: eases toward the real pointer position every
		// frame instead of snapping to it, so it always lags a little while
		// moving but settles dead-center once the pointer stops. Skipped on
		// touch devices (`transition:persist` keeps this exact element node
		// across view-transition navigations, so the loop/listeners below
		// only need to be set up this one time all session).
		const cursorDot = document.getElementById('cursor-dot');
		if (cursorDot && window.matchMedia('(pointer: fine)').matches) {
			const glyph = cursorDot.querySelector('span');
			let mouseX = window.innerWidth / 2;
			let mouseY = window.innerHeight / 2;
			let dotX = mouseX;
			let dotY = mouseY;
			let isHoveringBook = false;
			let isOverAbout = false;
			let isOverAboutLink = false;

			document.addEventListener('mousemove', (e) => {
				mouseX = e.clientX;
				mouseY = e.clientY;
			});

			document.addEventListener('mouseover', (e) => {
				if (e.target instanceof Element && e.target.closest('.book-cover-link')) isHoveringBook = true;
			});
			document.addEventListener('mouseout', (e) => {
				const isLeavingToAnotherBookEl =
					e.relatedTarget instanceof Element && e.relatedTarget.closest('.book-cover-link');
				if (!isLeavingToAnotherBookEl && e.target instanceof Element && e.target.closest('.book-cover-link')) {
					isHoveringBook = false;
				}
			});

			// The about section doubles as a scribble pad: click-and-drag draws
			// on #about-canvas in the primario red. Sized once here (rather than
			// on every resize) — simple tradeoff for what's a small easter egg,
			// not a full drawing tool. `transition:persist` on the canvas keeps
			// both the element and whatever's been drawn on it alive across
			// view-transition navigations (same trick as this cursor dot), so
			// this setup only needs to run once per session too.
			const aboutSection = document.getElementById('about-section');
			const aboutCanvas = document.getElementById('about-canvas');
			const drawCtx = aboutCanvas ? aboutCanvas.getContext('2d') : null;
			let isDrawing = false;
			let lastDrawX = 0;
			let lastDrawY = 0;

			if (aboutSection && aboutCanvas && drawCtx) {
				const rect = aboutSection.getBoundingClientRect();
				const dpr = window.devicePixelRatio || 1;
				aboutCanvas.width = rect.width * dpr;
				aboutCanvas.height = rect.height * dpr;
				aboutCanvas.style.width = `${rect.width}px`;
				aboutCanvas.style.height = `${rect.height}px`;
				drawCtx.scale(dpr, dpr);
				drawCtx.strokeStyle = getComputedStyle(document.documentElement).getPropertyValue('--color-primario').trim();
				drawCtx.lineWidth = 2;
				drawCtx.lineCap = 'round';
				drawCtx.lineJoin = 'round';
			}

			function drawPointFromEvent(e) {
				const rect = aboutCanvas.getBoundingClientRect();
				return { x: e.clientX - rect.left, y: e.clientY - rect.top };
			}

			document.addEventListener('mouseover', (e) => {
				if (e.target instanceof Element && e.target.closest('#about-section')) isOverAbout = true;
				if (e.target instanceof Element && e.target.closest('#about-section a')) isOverAboutLink = true;
			});
			document.addEventListener('mouseout', (e) => {
				const isLeavingToAnotherAboutEl =
					e.relatedTarget instanceof Element && e.relatedTarget.closest('#about-section');
				if (!isLeavingToAnotherAboutEl && e.target instanceof Element && e.target.closest('#about-section')) {
					isOverAbout = false;
					isDrawing = false;
				}
				const isLeavingToAnotherLink =
					e.relatedTarget instanceof Element && e.relatedTarget.closest('#about-section a');
				if (!isLeavingToAnotherLink && e.target instanceof Element && e.target.closest('#about-section a')) {
					isOverAboutLink = false;
				}
			});

			if (drawCtx) {
				document.addEventListener('mousedown', (e) => {
					if (!(e.target instanceof Element) || !e.target.closest('#about-section')) return;
					// Dragging over text would otherwise start a native text
					// selection (ugly blue highlight fighting the drawn line) —
					// preventDefault on the mousedown that kicks off the drag
					// stops that without disabling normal double/triple-click
					// text selection, which doesn't go through this handler.
					e.preventDefault();
					isDrawing = true;
					const p = drawPointFromEvent(e);
					lastDrawX = p.x;
					lastDrawY = p.y;
				});
				document.addEventListener('mousemove', (e) => {
					if (!isDrawing) return;
					const p = drawPointFromEvent(e);
					drawCtx.beginPath();
					drawCtx.moveTo(lastDrawX, lastDrawY);
					drawCtx.lineTo(p.x, p.y);
					drawCtx.stroke();
					lastDrawX = p.x;
					lastDrawY = p.y;
				});
				document.addEventListener('mouseup', () => {
					isDrawing = false;
				});
			}

			// Three mutually-exclusive looks for the dot, checked in priority
			// order: the detail modal's close affordance wins over the about
			// section's pencil (can't overlap in practice — #page-bg goes
			// inert while a book is open, so about-section hover can't fire —
			// but the priority keeps this correct even if that ever changes),
			// which wins over a plain book hover, which wins over idle.
			// wasMode guards every DOM write below so they only happen on an
			// actual state change rather than every frame — textContent in
			// particular replaces its text node on every assignment (unlike
			// classList.toggle, which no-ops when the class is already in
			// that state), so writing it 60x/sec regardless of whether it
			// changed was churning the DOM forever in the background and
			// showed up as janky cadence later on.
			let wasMode = '';
			(function tick() {
				dotX += (mouseX - dotX) * 0.1;
				dotY += (mouseY - dotY) * 0.1;
				cursorDot.style.transform = `translate3d(${dotX}px, ${dotY}px, 0) translate(-50%, -50%)`;

				const isBookOpen = !!document.getElementById('book-modal');
				const mode = isBookOpen
					? 'close'
					: isHoveringBook
						? 'plus'
						: isOverAbout && !isOverAboutLink
							? 'pencil'
							: 'idle';
				if (mode !== wasMode) {
					cursorDot.classList.toggle('cursor-dot--active', mode === 'close' || mode === 'plus');
					cursorDot.classList.toggle('cursor-dot--pencil', mode === 'pencil');
					if (glyph) glyph.textContent = mode === 'close' ? '×' : '+';
					wasMode = mode;
				}

				requestAnimationFrame(tick);
			})();
		}

		// Fixed footer bar: mirrors the filter bar's look, but only shown once
		// the filter bar has actually stuck to the top of the viewport (not
		// while still scrolling through the hero/about). position: sticky
		// alone doesn't expose a "currently stuck" state, so a sentinel placed
		// right before the sticky filter bar stands in for it — the sentinel
		// reliably scrolls out of view at exactly the moment its sticky
		// sibling starts pinning. Not gated behind pointer:fine (unlike the
		// cursor dot above) since back-to-top/footer visibility are just as
		// relevant on touch devices.
		const filterBarSentinel = document.getElementById('filter-bar-sentinel');
		const siteFooter = document.getElementById('site-footer');
		if (filterBarSentinel && siteFooter) {
			new IntersectionObserver(([entry]) => {
				// isIntersecting alone is ambiguous: it's equally false before
				// the sentinel has scrolled into view (below the viewport,
				// filter bar not stuck yet) and after it's scrolled past
				// (above the viewport, filter bar now stuck) — only the sign
				// of its position tells those two apart.
				const stuck = !entry.isIntersecting && entry.boundingClientRect.top < 0;
				siteFooter.classList.toggle('opacity-0', !stuck);
				siteFooter.classList.toggle('opacity-100', stuck);
				siteFooter.classList.toggle('pointer-events-none', !stuck);
				siteFooter.classList.toggle('pointer-events-auto', stuck);
			}).observe(filterBarSentinel);
		}

		const backToTopBtn = document.getElementById('btn-back-to-top');
		if (backToTopBtn) {
			backToTopBtn.addEventListener('click', () => {
				window.scrollTo({ top: 0, behavior: 'smooth' });
			});
		}

		// Escape closes the detail modal by re-using the real close link, so
		// it goes through the same navigation (and view transition) as
		// clicking it.
		document.addEventListener('keydown', (e) => {
			if (e.key !== 'Escape') return;
			const closeLink = document.querySelector('#book-modal a[aria-label="Cerrar"]');
			if (closeLink instanceof HTMLElement) closeLink.click();
		});

		// With the corner "×" button gone, the cursor dot is the only close
		// affordance shown — but the whole page still needs to act on it:
		// any click while the detail modal is open re-uses the real close
		// link (the dim backdrop), except real links (e.g. "Comprar", or
		// the close link itself, which already navigates on its own).
		document.addEventListener('click', (e) => {
			const modal = document.getElementById('book-modal');
			if (!modal) return;
			const target = e.target instanceof Element ? e.target : null;
			if (!target || target.closest('a[href]')) return;
			const closeLink = modal.querySelector('a[aria-label="Cerrar"]');
			if (closeLink instanceof HTMLElement) closeLink.click();
		});

		// The grid is built client-side, so the specific card a closing book
		// should shrink back into doesn't exist yet at the moment the browser
		// snapshots the destination page — Astro only re-runs page scripts
		// (which is what builds it) after that snapshot is already taken, so
		// landing precisely on the grid card isn't possible without
		// server-rendering the whole grid. Instead, on close, the whole modal
		// (cover + info panel together) gets a single standalone fade/blur
		// exit (see global.css): drop the cover's own morph name first so it
		// doesn't separately hunt for a same-page match, then name the
		// modal's content wrapper as one unit right before navigating away.
		// Delegated on document (not #book-modal, which doesn't exist yet the
		// first time this guarded, run-once block executes).
		document.addEventListener('click', (e) => {
			const link = e.target.closest('#book-modal a[aria-label="Cerrar"]');
			if (!link) return;
			const cover = document.querySelector('[style*="view-transition-name: book-cover"]');
			if (cover instanceof HTMLElement) cover.style.viewTransitionName = '';
			const content = document.getElementById('book-modal-content');
			if (content) content.style.viewTransitionName = 'book-modal-exit';
		});

		// Opening/closing the book detail is a real navigation (for the
		// shareable URL), which would otherwise reset scroll to the top and
		// make the blurred grid behind the modal jump. Remember where we
		// were right before leaving a page, and restore it once the next
		// one is ready, so the background stays put in both directions.
		const SCROLL_KEY = 'yauguru:scrollY';
		document.addEventListener('astro:before-preparation', () => {
			sessionStorage.setItem(SCROLL_KEY, String(window.scrollY));
		});
		document.addEventListener('astro:page-load', () => {
			const saved = sessionStorage.getItem(SCROLL_KEY);
			// The browser's own view-transition machinery (scrolling the
			// outgoing named element into view to snapshot it) can still
			// adjust scroll for a frame or two after astro:page-load fires,
			// silently winning over a scrollTo() called here directly.
			// Waiting two animation frames lets that settle first.
			requestAnimationFrame(() => {
				requestAnimationFrame(() => {
					if (saved !== null) {
						window.scrollTo(0, parseInt(saved, 10));
						return;
					}
					// No saved position means this book page was opened
					// directly (shared link, fresh tab, reload) rather than
					// clicked from the grid — there's nothing to "return"
					// to. Scroll to where the book sits in the (blurred)
					// grid instead of leaving the hero visible behind it.
					const modal = document.getElementById('book-modal');
					if (!modal) return;
					const match = location.pathname.match(/^\/libro\/([^/]+)/);
					const slug = match ? decodeURIComponent(match[1]) : null;
					const card = slug
						? document.querySelector(`.book-cover-link[href="/libro/${CSS.escape(slug)}"]`)
						: null;
					if (card) {
						const rect = card.getBoundingClientRect();
						const target = rect.top + window.scrollY - window.innerHeight / 2 + rect.height / 2;
						window.scrollTo(0, Math.max(target, 0));
					} else {
						document.getElementById('grid')?.scrollIntoView({ block: 'start' });
					}
				});
			});
		});
	}
</script>
